# 远程服务器运行配置 (示例)
M2W_HOST=0.0.0.0
M2W_PORT=80
M2W_BASE_URL=http://115.190.243.17:80
M2W_SITE_NAME=markdown2web (Prod)

# 后台管理
M2W_ADMIN_USERNAME=admin
M2W_ADMIN_PASSWORD=请修改此密码

# 功能开关
M2W_WATCH_ENABLED=false
M2W_TURNSTILE_ENABLED=true

# Cookie / 会话
# 公网 HTTPS 部署建议设为 true；本地 HTTP 开发保持 false
M2W_SECURE_COOKIES=false
M2W_SESSION_TTL_HOURS=168

# 限制配置 (上传视频时建议调大，如 512)
M2W_UPLOAD_LIMIT_MB=128

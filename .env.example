# Local / production template — copy to .env (gitignored) or use systemd EnvironmentFile.
# Scheme A production: app binds 127.0.0.1; Caddy/Nginx terminates TLS.

# --- listen (behind reverse proxy) ---
M2W_HOST=127.0.0.1
M2W_PORT=3000
# Public origin used in generated links (must match your domain)
M2W_BASE_URL=https://notes.example.com
M2W_SITE_NAME=markdown2web

# --- paths (absolute on server; relative OK for local cargo run) ---
# M2W_CONTENT_DIR=/opt/markdown2web/content
# M2W_GENERATED_DIR=/opt/markdown2web/generated/site
# M2W_DATA_DIR=/opt/markdown2web/data

# --- admin (change on first deploy; non-default password syncs into SQLite on start) ---
M2W_ADMIN_USERNAME=admin
M2W_ADMIN_PASSWORD=change-me-to-a-strong-password

# --- feature flags ---
# Production: manage content via /admin, disable fs watcher
M2W_WATCH_ENABLED=false
M2W_TURNSTILE_ENABLED=false
# M2W_TURNSTILE_SITE_KEY=
# M2W_TURNSTILE_SECRET_KEY=

# Upload size (MB). Raise for large videos; reverse proxy body limit must be ≥ this.
M2W_UPLOAD_LIMIT_MB=128

# RUST_LOG=markdown2web=info,tower_http=info
